{
    "name": "electron-ip-app",
    "version": "1.0.0",
    "description": "Aplicación para mostrar la IP",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder",
        "postinstall": "electron-builder install-app-deps"
    },
    "build": {
        "appId": "com.labelgrupnetworks.ipapp",
        "productName": "IP App",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": "nsis",
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "runAfterFinish": true
        }
    },
    "dependencies": {
        "electron-log": "^5.1.1",
        "electron-updater": "^6.2.1",
        "socket.io": "^4.8.1"
    },
    "devDependencies": {
        "electron": "^35.0.2",
        "electron-builder": "^24.13.3",
        "cors": "^2.8.5",
        "express": "^4.21.2"
    }
}